{
    "name": "qbits/laravel-inertia-vue-datatable",
    "description": "A powerful DataTable package for Laravel + Inertia.js + Vue 3 with server-side pagination, sorting, filtering, row selection, bulk actions, and export.",
    "type": "library",
    "keywords": [
        "laravel",
        "inertia",
        "vue",
        "datatable",
        "table",
        "pagination",
        "qbits"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "QBits",
            "email": "your@email.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "maatwebsite/excel": "^3.1"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "QBits\\InertiaDataTable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "QBits\\InertiaDataTable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "QBits\\InertiaDataTable\\InertiaDataTableServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}